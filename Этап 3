t):  # 袧袝 async!\n","    application_id = str(uuid.uuid4())\n","\n","    #  肖芯褉屑懈褉褍械屑 褋芯斜褘褌懈械\n","    event = {\n","        \"event_type\": \"ApplicationCreated\",\n","        \"data\": {\n","            \"application_id\": application_id,\n","            \"client_name\": request.client_name,\n","            \"amount\": request.amount,\n","            \"ssn\": request.ssn\n","        }\n","    }\n","\n","      # 袩褍斜谢懈泻褍械屑 胁 Redis 泻邪薪邪谢 芦fintech_events禄\n","    r.publish(\"fintech_events\", json.dumps(event))\n","\n","    r.hset(f\"app:{application_id}\", \"status\", \"processing\")\n","       #  袙芯蟹胁褉邪褖邪械屑 锌芯谢褜蟹芯胁邪褌械谢褞 ID 褋褉邪蟹褍, 薪械 卸写褢屑 褋泻芯褉懈薪谐邪\n","    return {\"status\": \"processing\", \"application_id\": application_id}\n","\n","@app.get(\"/api/v1/status/{app_id}\")\n","def get_status(app_id: str):\n","    # 袟写械褋褜 Gateway 写芯谢卸械薪 褋褏芯写懈褌褜 胁 褋胁芯褞 袘袛 (懈谢懈 泻褝褕), 泻褍写邪 Deal Service 褋泻懈薪褍谢 褎懈薪邪谢褜薪褘泄 褋褌邪褌褍褋\n","    # 袛谢褟 褍锌褉芯褖械薪懈褟 屑芯卸薪芯 褏褉邪薪懈褌褜 褋褌邪褌褍褋褘 胁 Redis\n","    status = r.hget(f\"app:{app_id}\", \"status\")\n","    return {\"status\": status or \"unknown\"}\n","\n","# SCORING (泻邪泻 胁 褌胁芯械屑 褋褌懈谢械)\n","def scoring():\n","    print(\"Scoring service 蟹邪锌褍褖械薪\")\n","    result = r.blpop(['fintech_events'], timeout=2)\n","    if result:\n","        data = json.loads(result[1])\n","        print(\"小泻芯褉懈薪谐\", data['data']['application_id'])\n","        #  袠屑懈褌邪褑懈褟 褋谢芯卸薪褘褏 褉邪褋褔械褌芯胁 (ML 屑芯写械谢懈 懈 褌.写.)\n","        time.sleep(8)\n","        # 袥芯谐懈泻邪 褋泻芯褉懈薪谐邪:\n","        score = 0.85 if data['data']['amount'] < 10000 else 0.45\n","        r.publish(\"fintech_events\", json.dumps({\n","            \"event_type\": \"ScoreCalculated\",\n","            \"data\": {**data['data'], \"score\": score}\n","        }))\n","        print(\"Score:\", score)\n","\n","# DEAL\n","def deal():\n","    print(\"Deal service 蟹邪锌褍褖械薪\")\n","    result = r.blpop(['fintech_events'], timeout=12)\n","    if result:\n","        data = json.loads(result[1])\n","        app_id = data['data']['application_id']\n","        time.sleep(3)\n","        status = \"approved\" if data['data']['score'] > 0.7 else \"rejected\"\n","        r.hset(f\"app:{app_id}\", \"status\", status)\n","        print(app_id, \"->\", status)\n","\n","if __name__ == \"__main__\":\n","    t1 = threading.Thread(target=scoring)\n","    t2 = threading.Thread(target=deal)\n","    t1.start(); t2.start()\n","\n","    time.sleep(1)\n","    resp = apply(ApplicationRequest(client_name=\"袠胁邪薪\", amount=5000, ssn=\"123\"))\n","    print(\"袟邪锌褉芯褋:\", resp)\n","\n","    time.sleep(12)\n","    print(\"肖懈薪邪谢:\", r.hget(f\"app:{resp['application_id']}\", \"status\"))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"FHO_FIf7ZPP9","executionInfo":{"status":"ok","timestamp":1775097657330,"user_tz":-600,"elapsed":14332,"user":{"displayName":"袛屑懈褌褉懈泄 小褍斜斜芯褌芯胁褋泻懈泄","userId":"10478367453596455262"}},"outputId":"c8394b10-8b9a-4a68-c995-4060e067fad3"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["Scoring service 蟹邪锌褍褖械薪Deal service 蟹邪锌褍褖械薪\n","\n","袟邪锌褉芯褋: {'status': 'processing', 'application_id': 'f6181ec1-df30-4c7f-ac3c-402fb8f96de7'}\n","肖懈薪邪谢: processing\n"]}]}]}